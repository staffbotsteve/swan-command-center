{
  "name": "swan-command-center",
  "version": "0.1.0",
  "private": true,
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "eslint",
    "test": "vitest run",
    "test:watch": "vitest",
    "worker": "node --env-file=.env.local --import tsx worker/index.ts",
    "worker:dev": "node --env-file=.env.local --import tsx --watch worker/index.ts",
    "channels:list-slack": "node --env-file=.env.local scripts/list-slack-channels.mjs",
    "channels:seed": "node --env-file=.env.local scripts/seed-channel-routing.mjs",
    "project:bootstrap": "node --env-file=.env.local scripts/bootstrap-project.mjs"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.119",
    "@google/generative-ai": "^0.24.1",
    "@octokit/rest": "^22.0.1",
    "@supabase/supabase-js": "^2.104.1",
    "mammoth": "^1.12.0",
    "next": "16.2.3",
    "next-auth": "^5.0.0-beta.31",
    "pdf-parse": "^2.4.5",
    "react": "19.2.4",
    "react-dom": "19.2.4"
  },
  "devDependencies": {
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/pg": "^8.20.0",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "eslint": "^9",
    "eslint-config-next": "16.2.3",
    "pg": "^8.20.0",
    "tailwindcss": "^4",
    "tsx": "^4.21.0",
    "typescript": "^5",
    "vitest": "^2.1.8"
  }
}
